---
import '../styles/global.css';
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Vteca</title>
  </head>
  <body id="dashboard-body" class="bg-slate-950 text-slate-300 font-sans antialiased h-screen flex opacity-0 transition-opacity duration-500 overflow-hidden">
    
    <aside class="w-72 bg-slate-950 border-r border-slate-800 flex flex-col hidden md:flex h-full z-20 shadow-2xl">
      <div class="h-24 flex items-center px-8 shrink-0">
        <div class="text-3xl font-black tracking-tighter text-white">vteca<span class="text-blue-500">.</span></div>
      </div>
      
      <nav class="flex-1 overflow-y-auto px-4 space-y-8 pb-8">
        <div>
          <p class="px-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3">Administración</p>
          <div class="space-y-1">
            <a href="/dashboard" class="nav-module flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl text-sm font-medium transition-colors">
              <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              Perfil y Cuenta
            </a>
            <a href="/dashboard/estadisticas" class="nav-module flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl text-sm font-medium transition-colors">
              <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
              Estadísticas
            </a>
          </div>
        </div>

        <div>
          <p class="px-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3">Operaciones</p>
          <div class="space-y-1">
            <a href="/dashboard/catalogo" class="nav-module flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl text-sm font-medium transition-colors">
              <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              Catálogo (Metadatos)
            </a>
            <a href="/dashboard/archivos" class="nav-module flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl text-sm font-medium transition-colors">
              <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
              Gestor de Archivos
            </a>
            <a href="/dashboard/configurar-sesion" class="nav-module flex items-center px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl text-sm font-medium transition-colors">
              <svg class="w-4 h-4 mr-3 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
              Vteca Live (Sesiones)
            </a>
          </div>
        </div>

        <div>
          <p class="px-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3">Ecosistema</p>
          <div class="space-y-1">
            <a href="/dashboard/editor" class="nav-module flex items-center justify-between px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl text-sm font-medium transition-colors group">
              <div class="flex items-center">
                <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                Editor de Video
              </div>
              <span class="text-[9px] font-bold bg-indigo-500/20 text-indigo-400 px-2 py-0.5 rounded uppercase tracking-wider">IA</span>
            </a>
          </div>
        </div>
      </nav>

      <div class="p-4 border-t border-slate-800 shrink-0">
        <button id="logout-btn" class="w-full flex items-center justify-between px-4 py-3 bg-slate-900 hover:bg-rose-500/10 border border-slate-800 hover:border-rose-500/30 rounded-xl transition-all group">
          <div class="flex items-center text-left">
            <div class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center text-xs font-bold text-white mr-3" id="avatar-initials">--</div>
            <div>
              <p class="text-xs font-bold text-white group-hover:text-rose-400 transition-colors">Cerrar Sesión</p>
              <p class="text-[10px] text-slate-500 truncate w-32" id="sidebar-email">Cargando...</p>
            </div>
          </div>
          <svg class="w-4 h-4 text-slate-600 group-hover:text-rose-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
        </button>
      </div>
    </aside>

    <main class="flex-1 overflow-y-auto p-8 lg:p-12 relative">
      <slot />
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';
      
      document.addEventListener('DOMContentLoaded', async () => {
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) return window.location.replace('/login');

        const { data: profile } = await supabase.from('profiles').select('*, institutions(*)').eq('id', user.id).single();
        if (!profile) return;

        // Script para resaltar el módulo actual en el menú lateral
        const currentPath = window.location.pathname.replace(/\/$/, "");
        document.querySelectorAll('a.nav-module').forEach(link => {
          const linkPath = link.getAttribute('href')?.replace(/\/$/, "");
          if (linkPath === currentPath) {
            link.classList.remove('text-slate-400', 'hover:bg-slate-800/50');
            link.classList.add('bg-slate-900', 'text-white', 'border', 'border-slate-800', 'shadow-lg');
            // Pintamos el SVG de azul si es el activo
            const icon = link.querySelector('svg');
            if(icon) icon.classList.add('text-blue-500');
          }
        });

        // Configuración de UI del usuario
        const initials = profile.full_name ? profile.full_name.substring(0, 2).toUpperCase() : 'AD';
        const avatarEl = document.getElementById('avatar-initials');
        const emailEl = document.getElementById('sidebar-email');
        if(avatarEl) avatarEl.textContent = initials;
        if(emailEl) emailEl.textContent = user.email!;
        
        document.body.classList.remove('opacity-0');
      });

      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/login';
      });
    </script>
  </body>
</html>