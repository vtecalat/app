---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Mi Perfil">
  
  <header class="flex flex-col md:flex-row md:justify-between md:items-end mb-12 gap-4">
    <div>
      <h1 id="inst-name" class="text-4xl font-black text-white tracking-tight">Cargando datos...</h1>
      <p id="user-role" class="text-slate-400 text-sm mt-2 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-blue-500"></span>
        Panel de Administración Global
      </p>
    </div>
    <div>
      <div id="status-badge" class="px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider bg-slate-900 text-slate-500 border border-slate-800">
        Verificando...
      </div>
    </div>
  </header>

  <div id="pending-state" class="hidden bg-amber-500/10 border border-amber-500/20 p-6 rounded-2xl mb-8 flex items-start gap-5 shadow-lg">
    <div class="p-3 bg-amber-500/20 rounded-xl text-amber-400 shrink-0 border border-amber-500/30">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
    </div>
    <div>
      <h3 class="font-bold text-amber-400 mb-1">Entorno en auditoría técnica</h3>
      <p class="text-sm text-slate-300 leading-relaxed max-w-4xl">Su cuenta y subdominio están siendo aprovisionados por nuestro equipo de arquitectura. Puede adelantar la configuración de su perfil y subir la identidad visual institucional.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <div class="lg:col-span-1 bg-slate-900 border border-slate-800 p-8 rounded-3xl shadow-xl flex flex-col justify-between">
      <div>
        <h2 class="text-lg font-bold text-white mb-6 flex items-center">
          <svg class="w-5 h-5 mr-3 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          Perfil Técnico
        </h2>
        <div class="space-y-5">
          <div>
            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Responsable / Admin</label>
            <input type="text" id="full-name" class="w-full bg-slate-950 border border-slate-800 rounded-xl p-3.5 text-sm text-white focus:outline-none focus:border-blue-500 transition-all" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Correo (Solo lectura)</label>
            <input type="email" id="email" disabled class="w-full bg-slate-950/50 border border-transparent rounded-xl p-3.5 text-sm text-slate-500 cursor-not-allowed" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">WhatsApp Directo</label>
            <input type="text" id="user-whatsapp" class="w-full bg-slate-950 border border-slate-800 rounded-xl p-3.5 text-sm text-white focus:outline-none focus:border-blue-500 transition-all" />
          </div>
        </div>
      </div>
      <button id="save-profile" class="w-full mt-8 bg-blue-600 hover:bg-blue-500 text-white py-3.5 rounded-xl text-sm font-bold shadow-lg transition-colors">Guardar Perfil</button>
    </div>

    <div class="lg:col-span-2 space-y-6 flex flex-col justify-between">
      
      <div class="bg-slate-900 border border-slate-800 p-8 rounded-3xl shadow-xl">
        <h2 class="text-lg font-bold text-white mb-6 flex items-center">
          <svg class="w-5 h-5 mr-3 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          Identidad Visual e Imagen Corporativa
        </h2>
        
        <div class="flex flex-col md:flex-row items-center gap-8 mb-6">
          <div class="w-32 h-32 rounded-2xl bg-slate-950 border border-slate-800 flex flex-col items-center justify-center overflow-hidden shrink-0 relative group">
            <img id="logo-preview" class="w-full h-full object-cover hidden" src="" alt="Logo institucional" />
            <div id="logo-placeholder" class="text-center p-2 text-slate-600">
              <svg class="w-8 h-8 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              <span class="text-[10px] uppercase font-bold tracking-wider">Sin Logo</span>
            </div>
          </div>

          <div class="flex-1 space-y-3 w-full">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center justify-between">
              Cargar Logotipo Oficial
              <span class="text-[9px] bg-slate-800 text-slate-300 px-2 py-0.5 rounded">Máx. 1 MB</span>
            </label>
            <p class="text-xs text-slate-500">Sube el escudo o logotipo de tu organización (JPG, PNG). Asegúrate de que el archivo pese menos de 1 MB para garantizar tiempos de carga óptimos en tu videoteca.</p>
            <input type="file" id="logo-file-input" accept="image/png, image/jpeg, image/webp" class="w-full text-sm text-slate-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-slate-800 file:text-slate-200 hover:file:bg-slate-700 file:cursor-pointer transition-colors" />
            <p id="upload-status" class="text-xs font-medium hidden"></p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-5 border-t border-slate-800/60 pt-6">
          <div>
            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Web Institucional</label>
            <input type="text" id="inst-web" class="w-full bg-slate-950 border border-slate-800 rounded-xl p-3.5 text-sm text-white focus:outline-none focus:border-blue-500 transition-colors" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Enrutamiento Vteca</label>
            <div class="flex">
              <input type="text" id="inst-subdomain" disabled class="w-full bg-slate-950/50 border border-slate-800 rounded-l-xl p-3.5 text-sm text-slate-500 text-right cursor-not-allowed" />
              <span class="bg-slate-950 border border-slate-800 border-l-0 rounded-r-xl px-4 py-3.5 text-sm text-slate-600 flex items-center font-mono">.vteca.lat</span>
            </div>
          </div>
        </div>
        <button id="save-inst" class="mt-6 bg-slate-800 hover:bg-slate-700 text-white px-6 py-3 rounded-xl text-sm font-bold transition-colors shadow-lg">Actualizar Organización</button>
      </div>

      <div class="bg-slate-900 border border-slate-800 p-8 rounded-3xl shadow-xl border-l-4 border-l-emerald-500">
        <h2 class="text-lg font-bold text-white mb-2">Continuidad del Acervo</h2>
        <p class="text-sm text-slate-400 mb-6">Vincule un correo institucional secundario para asegurar el rescate de la plataforma si el administrador principal pierde el acceso.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <input type="email" id="recovery-email" class="flex-1 bg-slate-950 border border-slate-800 rounded-xl p-3.5 text-sm text-white focus:outline-none focus:border-emerald-500 transition-colors" placeholder="ej. sistemas@universidad.edu" />
          <button id="save-recovery" class="bg-emerald-600 hover:bg-emerald-500 text-white px-8 py-3.5 rounded-xl text-sm font-bold shadow-lg transition-colors">Asegurar Acceso</button>
        </div>
      </div>

    </div>
  </div>
</DashboardLayout>

<script>
  import { supabase } from '../../lib/supabase.js';

  const imgbbKey = import.meta.env.PUBLIC_IMGBB_API_KEY;

  const loadData = async () => {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    const { data: profile } = await supabase
      .from('profiles')
      .select('*, institutions(*)')
      .eq('id', user.id)
      .single();
    
    if (!profile || !profile.institutions) return;

    document.getElementById('inst-name')!.textContent = profile.institutions.name;
    document.getElementById('user-role')!.innerHTML = `<span class="w-2 h-2 rounded-full bg-blue-500"></span> Rol: ${profile.role === 'superadmin' ? 'Dueño de Infraestructura' : 'Administrador de Videoteca'}`;
    
    (document.getElementById('full-name') as HTMLInputElement).value = profile.full_name || '';
    (document.getElementById('email') as HTMLInputElement).value = user.email || '';
    (document.getElementById('user-whatsapp') as HTMLInputElement).value = profile.whatsapp || '';
    (document.getElementById('inst-web') as HTMLInputElement).value = profile.institutions.website || '';
    (document.getElementById('inst-subdomain') as HTMLInputElement).value = profile.institutions.subdomain?.replace('inst-', '') || '';
    (document.getElementById('recovery-email') as HTMLInputElement).value = profile.recovery_email || '';
    
    // Si la institución ya tiene logo guardado, lo mostramos
    const preview = document.getElementById('logo-preview') as HTMLImageElement;
    const placeholder = document.getElementById('logo-placeholder');
    if (profile.institutions.logo_url) {
      preview.src = profile.institutions.logo_url;
      preview.classList.remove('hidden');
      placeholder?.classList.add('hidden');
    }

    const statusBadge = document.getElementById('status-badge');
    if (profile.institutions.status === 'active') {
      if (statusBadge) {
        statusBadge.textContent = 'Sistema Operativo';
        statusBadge.className = 'px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
      }
    } else {
      if (statusBadge) {
        statusBadge.textContent = 'En Auditoría';
        statusBadge.className = 'px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider bg-amber-500/10 text-amber-500 border border-amber-500/20';
      }
      document.getElementById('pending-state')!.classList.remove('hidden');
    }
  };

  // --- LÓGICA DE SUBIDA IMGBB CON VALIDACIÓN DE PESO ---
  const fileInput = document.getElementById('logo-file-input') as HTMLInputElement;
  const uploadStatus = document.getElementById('upload-status');
  const MAX_FILE_SIZE = 1048576; // 1 MB en bytes

  fileInput?.addEventListener('change', async (e) => {
    const target = e.target as HTMLInputElement;
    if (!target.files || target.files.length === 0) return;

    const file = target.files[0];

    // Validación de peso estricta (1MB)
    if (file.size > MAX_FILE_SIZE) {
      if (uploadStatus) {
        uploadStatus.textContent = 'Error: La imagen supera el límite de 1 MB. Por favor, comprima el archivo.';
        uploadStatus.className = 'text-xs text-rose-400 font-bold';
        uploadStatus.classList.remove('hidden');
      }
      // Limpiamos el input para obligar a seleccionar de nuevo
      target.value = ''; 
      return;
    }

    const formData = new FormData();
    formData.append('image', file);

    if (uploadStatus) {
      uploadStatus.textContent = 'Subiendo logotipo a la red CDN...';
      uploadStatus.className = 'text-xs text-blue-400 font-semibold';
      uploadStatus.classList.remove('hidden');
    }

    try {
      const response = await fetch(`https://api.imgbb.com/1/upload?key=${imgbbKey}`, {
        method: 'POST',
        body: formData
      });

      const result = await response.json();

      if (result.success) {
        const directImageUrl = result.data.url;

        const { data: { user } } = await supabase.auth.getUser();
        const { data: profile } = await supabase.from('profiles').select('institution_id').eq('id', user!.id).single();
        
        // Se guarda en Supabase, en la columna que acabas de crear mediante SQL
        const { error } = await supabase.from('institutions').update({ logo_url: directImageUrl }).eq('id', profile!.institution_id);
        
        if (error) throw error;

        const preview = document.getElementById('logo-preview') as HTMLImageElement;
        preview.src = directImageUrl;
        preview.classList.remove('hidden');
        document.getElementById('logo-placeholder')?.classList.add('hidden');

        if (uploadStatus) {
          uploadStatus.textContent = '¡Identidad visual sincronizada y guardada con éxito!';
          uploadStatus.className = 'text-xs text-emerald-400 font-semibold';
        }
      } else {
        throw new Error('Error en ImgBB');
      }
    } catch (err) {
      console.error(err);
      if (uploadStatus) {
        uploadStatus.textContent = 'Fallo en la carga de imagen. Intente nuevamente.';
        uploadStatus.className = 'text-xs text-rose-400 font-bold';
      }
    }
  });

  // Guardado general
  const setupSaveButton = (btnId: string, table: string, dataKeyBuilder: () => object, successText: string) => {
    document.getElementById(btnId)?.addEventListener('click', async () => {
      const btn = document.getElementById(btnId) as HTMLButtonElement;
      const originalText = btn.textContent;
      btn.textContent = 'Guardando...';
      btn.disabled = true;

      const { data: { user } } = await supabase.auth.getUser();
      const dataToUpdate = dataKeyBuilder();
      
      if (table === 'profiles') {
        await supabase.from('profiles').update(dataToUpdate).eq('id', user!.id);
      } else {
        const { data: profile } = await supabase.from('profiles').select('institution_id').eq('id', user!.id).single();
        await supabase.from('institutions').update(dataToUpdate).eq('id', profile!.institution_id);
      }
      
      btn.textContent = successText;
      setTimeout(() => { btn.textContent = originalText; btn.disabled = false; }, 2000);
    });
  };

  setupSaveButton('save-profile', 'profiles', () => ({
    full_name: (document.getElementById('full-name') as HTMLInputElement).value,
    whatsapp: (document.getElementById('user-whatsapp') as HTMLInputElement).value
  }), '¡Perfil Guardado!');

  setupSaveButton('save-inst', 'institutions', () => ({
    website: (document.getElementById('inst-web') as HTMLInputElement).value
  }), '¡Actualizado!');

  setupSaveButton('save-recovery', 'profiles', () => ({
    recovery_email: (document.getElementById('recovery-email') as HTMLInputElement).value
  }), '¡Correo Asegurado!');

  loadData();
</script>