---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Estudio Principal">
    <div id="control-workspace" class="max-w-[1600px] mx-auto h-full flex flex-col gap-6">
        
        <header class="bg-slate-900 border border-slate-800 rounded-2xl p-6 flex flex-col md:flex-row justify-between items-center gap-4 shadow-xl shrink-0">
            <div class="flex items-center gap-4 w-full md:w-auto">
                <a href="/dashboard/configurar-sesion" class="text-slate-500 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                </a>
                <div class="w-px h-8 bg-slate-800 hidden md:block"></div>
                <div class="flex-1 min-w-0">
                    <h1 id="control-session-title" class="text-2xl font-black text-white truncate">Cargando Sesión...</h1>
                    <p class="text-xs text-slate-500 uppercase tracking-widest mt-1">Estudio de Producción</p>
                </div>
            </div>
            
            <div class="flex items-center gap-4">
                <div id="live-status-badge" class="px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider bg-slate-800 text-slate-400 border border-slate-700">
                    Conectando...
                </div>
                <button id="btn-stream-action" class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-lg transition-all">
                    Cargando...
                </button>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 shrink-0">
            
            <div class="flex flex-col gap-4">
                <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
                    <div class="bg-slate-950 px-4 py-3 border-b border-slate-800 flex justify-between items-center">
                        <h3 class="text-slate-300 font-bold text-sm flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-slate-500"></span>
                            Fuente de Video (Preview)
                        </h3>
                        <button id="btn-activate-camera" class="bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-1.5 rounded-lg text-xs font-bold transition-colors">
                            Conectar Fuente
                        </button>
                    </div>
                    <div class="aspect-video bg-black w-full relative p-2">
                        <p class="text-xs text-slate-600 text-center mt-4 absolute w-full left-0">Conecta tu cámara o captura de pantalla.</p>
                        <div id="self-camera-wrapper" class="hidden w-full h-full relative z-10 border border-slate-800 rounded-lg overflow-hidden bg-slate-950">
                            <iframe id="self-camera-iframe" src="" allow="camera; microphone; display-capture; autoplay" class="w-full h-full border-none absolute inset-0"></iframe>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-xl overflow-hidden">
                    <button id="btn-toggle-links" class="w-full bg-slate-950 px-5 py-4 flex justify-between items-center hover:bg-slate-800/50 transition-colors">
                        <h3 class="text-white font-bold text-sm flex items-center gap-2">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                            Producción y Enlaces
                        </h3>
                        <svg id="accordion-icon" class="w-5 h-5 text-slate-500 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </button>

                    <div id="links-accordion-content" class="p-5 space-y-4 border-t border-slate-800 hidden">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="flex justify-between items-center bg-slate-950 p-3 rounded-xl border border-slate-800">
                                <span class="text-xs text-slate-400">Enlace Director</span>
                                <button id="btn-copy-director" class="text-slate-500 hover:text-white transition-colors p-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></button>
                            </div>
                            <div class="flex justify-between items-center bg-slate-950 p-3 rounded-xl border border-slate-800">
                                <span class="text-xs text-slate-400">Enlace Invitados</span>
                                <button id="btn-copy-guest" class="text-slate-500 hover:text-white transition-colors p-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></button>
                            </div>
                            <div class="flex justify-between items-center bg-slate-950 p-3 rounded-xl border border-slate-800 md:col-span-2">
                                <span class="text-xs text-slate-400">Salida OBS Limpia</span>
                                <button id="btn-copy-obs" class="text-slate-500 hover:text-white transition-colors p-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></button>
                            </div>
                        </div>

                        <div class="bg-slate-950 border border-orange-500/30 rounded-xl p-4 mt-2">
                            <h4 class="text-orange-400 font-bold text-[10px] uppercase tracking-wider mb-2">Conexión RTMP Alternativa</h4>
                            <div class="space-y-1 text-xs font-mono">
                                <div><span class="text-slate-500">Servidor:</span> <span id="obs-stream-url" class="text-slate-300">...</span></div>
                                <div><span class="text-slate-500">Clave:</span> <span id="obs-stream-key" class="text-emerald-400 filter blur-[3px] hover:blur-none cursor-pointer transition-all">...</span></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="monitor-wrapper" class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl hidden flex flex-col">
                <div class="bg-slate-950 px-4 py-3 border-b border-slate-800 flex justify-between items-center">
                    <h3 class="text-rose-400 font-bold text-sm flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>
                        Señal Pública (Program)
                    </h3>
                    <span class="text-[9px] uppercase font-bold text-amber-500 bg-amber-500/10 px-2 py-1 rounded">Retraso de Red</span>
                </div>
                <div class="flex-1 bg-black w-full relative">
                    <iframe id="monitor-iframe" src="" allow="autoplay; encrypted-media" allowfullscreen class="w-full h-full border-none absolute inset-0"></iframe>
                </div>
            </div>

        </div>

        <div id="director-section" class="flex-1 min-h-[700px] bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-2xl flex flex-col hidden">
            <div class="bg-slate-950 px-4 py-3 border-b border-slate-800 flex justify-between items-center">
                <h3 class="text-blue-400 font-bold text-sm flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                    Sala del Director
                </h3>
                <button id="btn-open-director" class="text-xs font-bold text-slate-400 hover:text-white transition-colors flex items-center gap-2">
                    Abrir en nueva pestaña
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </button>
            </div>
            <div class="flex-1 w-full bg-black relative">
                <iframe id="director-iframe" src="" allow="camera; microphone; display-capture; autoplay" class="w-full h-full border-none absolute inset-0"></iframe>
            </div>
        </div>

    </div>
</DashboardLayout>

<script>
    import { ControlRoomController } from '../../logic/controlRoomController.js';
    const room = new ControlRoomController();
    room.init();
</script>