---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Centro de Comando">
    <div id="control-workspace" class="max-w-7xl mx-auto h-full flex flex-col gap-6">
        
        <header class="bg-slate-900 border border-slate-800 rounded-2xl p-6 flex flex-col md:flex-row justify-between items-center gap-4 shadow-xl">
            <div class="flex items-center gap-4">
                <a href="/dashboard" class="text-slate-500 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                </a>
                <div class="w-px h-8 bg-slate-800"></div>
                <div>
                    <h1 id="control-title" class="text-2xl font-black text-white">Cargando Sesión...</h1>
                    <p class="text-xs text-slate-500 uppercase tracking-widest mt-1">Centro de Comando</p>
                </div>
            </div>
            
            <div class="flex items-center gap-4">
                <div id="live-status-badge" class="px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider bg-slate-800 text-slate-400 border border-slate-700">
                    Conectando...
                </div>
                <button id="btn-stream-action" class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-lg shadow-emerald-900/20 transition-all flex items-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
                    Iniciar Evento
                </button>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 flex-1">
            
            <div class="lg:col-span-2 space-y-6">
                
                <div id="camera-wrapper" class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl hidden">
                    <div class="bg-slate-950 px-4 py-3 border-b border-slate-800 flex justify-between items-center">
                        <h3 class="text-emerald-400 font-bold text-sm flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                            Estudio Interno (Mixer)
                        </h3>
                    </div>
                    <div class="aspect-video bg-black w-full relative">
                        <iframe id="camera-iframe" src="" allow="camera; microphone; display-capture; autoplay" class="w-full h-full border-none absolute inset-0"></iframe>
                    </div>
                </div>

                <div id="obs-instructions" class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-xl border-l-4 border-l-rose-500 hidden">
                    <h3 class="text-rose-400 font-bold mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                        Conexión con OBS Studio
                    </h3>
                    <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 font-mono text-sm space-y-3">
                        <div>
                            <span class="text-slate-500">Servidor / URL:</span><br>
                            <span id="obs-stream-url" class="text-blue-400 break-all">Cargando...</span>
                        </div>
                        <div>
                            <span class="text-slate-500">Clave de Transmisión / Origen:</span><br>
                            <span id="obs-stream-key" class="text-emerald-400 break-all filter blur-[4px] hover:blur-none cursor-pointer transition-all" title="Pasa el mouse para revelar">Cargando...</span>
                        </div>
                    </div>
                </div>

            </div>

            <div class="lg:col-span-1 space-y-6 flex flex-col">
                <div class="bg-slate-900 border border-slate-800 rounded-2xl flex-1 flex flex-col shadow-xl min-h-[400px]">
                    <div class="px-6 py-4 border-b border-slate-800 flex justify-between items-center">
                        <h3 class="text-white font-bold flex items-center gap-2">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                            Chat en Vivo
                        </h3>
                    </div>
                    <div class="flex-1 p-6 flex flex-col justify-center items-center text-slate-500 text-sm">
                        <i class="fa-solid fa-lock mb-2 text-2xl"></i>
                        <p>El chat se activará al iniciar el evento.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</DashboardLayout>

<script>
    import { ControlRoomController } from '../../logic/controlRoomController.js';
    const room = new ControlRoomController();
    room.init();
</script>