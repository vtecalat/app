---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Crear Cuenta Institucional | Vteca</title>
  </head>
  <body class="bg-slate-900 text-stone-100 font-sans antialiased min-h-screen flex items-center justify-center p-6 py-12">
    
    <div class="w-full max-w-2xl">
      <!-- Encabezado del Formulario -->
      <div class="text-center mb-8">
        <div class="text-3xl font-bold tracking-tighter mb-2">vteca<span class="text-blue-900">.</span></div>
        <h1 class="text-2xl font-semibold text-stone-100">Registro Institucional</h1>
        <p class="text-slate-400 text-sm mt-2">Complete el perfil de su organización para crear su cuenta.</p>
      </div>

      <!-- Tarjeta del Formulario -->
      <div class="bg-[#1a1c23] border border-slate-700/50 p-8 rounded-xl shadow-2xl relative overflow-hidden">
        <!-- Detalle de color superior -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-900 via-slate-700 to-rose-900"></div>

        <form id="registro-form" class="space-y-8">
          
          <!-- 1. Datos de la Institución -->
          <div class="space-y-4">
            <h2 class="text-xs font-bold text-blue-900 uppercase tracking-widest border-b border-slate-700 pb-2">1. Entidad Educativa / Organizacional</h2>
            
            <div>
              <label class="block text-xs font-semibold text-slate-400 mb-1">Nombre Completo de la Institución</label>
              <input type="text" id="inst-name" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-blue-900 transition-colors" placeholder="Ej. Universidad Central / Ministerio de Cultura">
            </div>
            
            <div class="grid sm:grid-cols-2 gap-4 items-start">
              <div class="sm:col-span-1">
                <label class="block text-xs font-semibold text-slate-400 mb-1">Sitio Web Institucional</label>
                <input type="url" id="inst-web" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-blue-900 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" placeholder="https://www.universidad.edu">
              </div>
              <div class="sm:col-span-1 flex items-center h-full pt-4">
                <label class="flex items-center space-x-2 cursor-pointer group">
                  <input type="checkbox" id="no-web-checkbox" class="w-4 h-4 rounded border-slate-700 bg-slate-900/50 text-blue-900 focus:ring-blue-900 focus:ring-offset-slate-900 cursor-pointer">
                  <span class="text-xs text-slate-400 group-hover:text-stone-200 transition-colors">La institución no cuenta con sitio web activo</span>
                </label>
              </div>
            </div>
          </div>

          <!-- 2. Credenciales del Administrador -->
          <div class="space-y-4">
            <h2 class="text-xs font-bold text-rose-900 uppercase tracking-widest border-b border-slate-700 pb-2">2. Perfil del Responsable Técnico / Académico</h2>
            
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-400 mb-1">Nombres</label>
                <input type="text" id="admin-first-name" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-rose-900 transition-colors" placeholder="Ej. Carlos">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-400 mb-1">Apellidos</label>
                <input type="text" id="admin-last-name" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-rose-900 transition-colors" placeholder="Ej. Mendoza">
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-400 mb-1">Cargo Institucional</label>
                <input type="text" id="admin-role" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-rose-900 transition-colors" placeholder="Ej. Director de Biblioteca">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-400 mb-1">País</label>
                <select id="admin-country" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-rose-900 transition-colors text-stone-200">
                  <option value="" disabled selected>Seleccione un país...</option>
                  <option value="Perú" data-code="+51">Perú (+51)</option>
                  <option value="Colombia" data-code="+57">Colombia (+57)</option>
                  <option value="México" data-code="+52">México (+52)</option>
                  <option value="Chile" data-code="+56">Chile (+56)</option>
                  <option value="Argentina" data-code="+54">Argentina (+54)</option>
                  <option value="España" data-code="+34">España (+34)</option>
                  <option value="Otro" data-code="">Otro</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-400 mb-1">Correo Electrónico Institucional (Acceso Principal)</label>
              <input type="email" id="admin-email" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-rose-900 transition-colors" placeholder="c.mendoza@universidad.edu">
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-400 mb-1">Teléfono Fijo / Extensión</label>
                <input type="tel" id="admin-phone" class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-rose-900 transition-colors" placeholder="123 4567">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-400 mb-1">WhatsApp Móvil (Directo)</label>
                <input type="tel" id="admin-whatsapp" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-rose-900 transition-colors" placeholder="999 888 777">
              </div>
            </div>
          </div>

          <!-- 3. Parámetros de Seguridad y Cierre -->
          <div class="space-y-6 pt-4 bg-slate-900/30 p-6 rounded-lg border border-slate-800">
            <h2 class="text-xs font-bold text-emerald-600 uppercase tracking-widest border-b border-slate-700 pb-2">3. Seguridad y Método de Acceso</h2>
            
            <!-- Correo de Recuperación -->
            <div>
              <label class="block text-xs font-semibold text-slate-300 mb-1">Correo de Recuperación (Personal / Decanatura)</label>
              <p class="text-[10px] text-slate-500 mb-2">Fundamental si el responsable de la cuenta deja la institución para garantizar la continuidad del acceso.</p>
              <input type="email" id="recovery-email" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-700 transition-colors" placeholder="ejemplo@gmail.com / decanato@universidad.edu">
            </div>

            <div class="grid md:grid-cols-2 gap-8 pt-4">
              
              <!-- Opción A: Contraseña -->
              <div class="space-y-4 border-r border-slate-700/50 pr-4">
                <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest text-center mb-4">Opción A: Tradicional</div>
                <div>
                  <label class="block text-xs font-semibold text-slate-400 mb-1">Contraseña Segura</label>
                  <input type="password" id="admin-password" minlength="8" class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-blue-900 transition-colors" placeholder="Mínimo 8 caracteres">
                </div>
                <div>
                  <label class="block text-xs font-semibold text-slate-400 mb-1">Verificar Contraseña</label>
                  <input type="password" id="admin-password-confirm" minlength="8" class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-blue-900 transition-colors" placeholder="Repita la contraseña">
                </div>
                <button type="submit" id="submit-btn" class="w-full py-3 mt-4 bg-blue-950 text-stone-100 border border-blue-900 hover:bg-blue-900 font-bold rounded-md transition-colors text-sm shadow-lg">
                  Crear Cuenta con Contraseña
                </button>
              </div>

              <!-- Opción B: Google -->
              <div class="flex flex-col justify-center space-y-4 pl-2">
                <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest text-center mb-2">Opción B: SSO Institucional</div>
                <p class="text-[11px] text-slate-400 text-center leading-relaxed mb-2">Recomendado si su institución utiliza el ecosistema corporativo de Google Workspace.</p>
                <button id="google-auth-btn" type="button" class="w-full py-3 bg-white text-slate-900 hover:bg-slate-200 font-bold rounded-md transition-colors text-sm flex justify-center items-center gap-2 shadow-md">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                  </svg>
                  Registrarse con Google
                </button>
              </div>

            </div>
          </div>

          <!-- Mensajes de Error/Éxito -->
          <div id="form-message" class="hidden text-sm p-3 rounded-md mt-4 font-medium"></div>

        </form>
        
        <div class="mt-8 text-center text-xs text-slate-500">
          Al crear la cuenta, acepta los <a href="#" class="text-blue-800 hover:underline">Términos de Soberanía de Datos</a> y <a href="#" class="text-blue-800 hover:underline">Políticas de IP</a> de Vteca.
        </div>
      </div>
    </div>

    <!-- Script de conexión con Supabase e interactividad -->
    <script>
      import { supabase } from '../lib/supabase.js';

      const form = document.getElementById('registro-form') as HTMLFormElement;
      const messageDiv = document.getElementById('form-message');
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const googleBtn = document.getElementById('google-auth-btn') as HTMLButtonElement;
      
      // Función para recolectar datos del formulario
      const getFormData = () => {
        const webInput = document.getElementById('inst-web') as HTMLInputElement;
        return {
          institution_name: (document.getElementById('inst-name') as HTMLInputElement).value,
          website: webInput.disabled ? 'No tiene web' : webInput.value,
          first_name: (document.getElementById('admin-first-name') as HTMLInputElement).value,
          last_name: (document.getElementById('admin-last-name') as HTMLInputElement).value,
          institutional_role: (document.getElementById('admin-role') as HTMLInputElement).value,
          country: (document.getElementById('admin-country') as HTMLSelectElement).value,
          phone: (document.getElementById('admin-phone') as HTMLInputElement).value,
          whatsapp: (document.getElementById('admin-whatsapp') as HTMLInputElement).value,
          recovery_email: (document.getElementById('recovery-email') as HTMLInputElement).value,
        };
      };

      // Lógica del Checkbox de Sitio Web
      const noWebCheckbox = document.getElementById('no-web-checkbox');
      const webInput = document.getElementById('inst-web');

      if (noWebCheckbox && webInput) {
        noWebCheckbox.addEventListener('change', (e) => {
          const isChecked = (e.target as HTMLInputElement).checked;
          (webInput as HTMLInputElement).disabled = isChecked;
          if (isChecked) {
            (webInput as HTMLInputElement).value = '';
            (webInput as HTMLInputElement).removeAttribute('required');
          } else {
            (webInput as HTMLInputElement).setAttribute('required', 'true');
          }
        });
      }

      // Lógica de Autocompletado de Código de País
      const countrySelect = document.getElementById('admin-country') as HTMLSelectElement;
      const phoneInput = document.getElementById('admin-phone') as HTMLInputElement;
      const whatsappInput = document.getElementById('admin-whatsapp') as HTMLInputElement;

      if (countrySelect) {
        countrySelect.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          const selectedOption = target.options[target.selectedIndex];
          const code = selectedOption.getAttribute('data-code');
          
          if (code) {
            // Solo inserta el código si el campo está vacío o empieza con un código anterior
            if (!phoneInput.value || phoneInput.value.startsWith('+')) {
              phoneInput.value = code + ' ';
            }
            if (!whatsappInput.value || whatsappInput.value.startsWith('+')) {
              whatsappInput.value = code + ' ';
            }
          }
        });
      }

      // Lógica de Registro con Google (OAuth)
      if (googleBtn) {
        googleBtn.addEventListener('click', async () => {
          const pass1 = document.getElementById('admin-password') as HTMLInputElement;
          const pass2 = document.getElementById('admin-password-confirm') as HTMLInputElement;
          
          pass1.removeAttribute('required');
          pass2.removeAttribute('required');

          if (!form.checkValidity()) {
            form.reportValidity(); 
            return;
          }

          localStorage.setItem('vteca_pending_registration', JSON.stringify(getFormData()));

          googleBtn.innerHTML = 'Conectando con Google...';
          googleBtn.disabled = true;

          const { error } = await supabase.auth.signInWithOAuth({
            provider: 'google',
            options: {
              redirectTo: window.location.origin + '/dashboard?setup=true'
            }
          });

          if (error) {
            console.error('Error al iniciar sesión con Google:', error.message);
            googleBtn.innerHTML = 'Registrarse con Google';
            googleBtn.disabled = false;
          }
        });
      }

      // Lógica de Registro Manual con Contraseña
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          const password = (document.getElementById('admin-password') as HTMLInputElement).value;
          const confirmPassword = (document.getElementById('admin-password-confirm') as HTMLInputElement).value;

          if(!password || !confirmPassword) {
             if (messageDiv) {
              messageDiv.className = 'text-sm p-3 rounded-md bg-rose-900/30 text-rose-400 border border-rose-800';
              messageDiv.textContent = 'Debe ingresar y confirmar una contraseña.';
              messageDiv.classList.remove('hidden');
            }
            return;
          }

          if (messageDiv) {
            messageDiv.classList.add('hidden');
          }

          if (password !== confirmPassword) {
            if (messageDiv) {
              messageDiv.className = 'text-sm p-3 rounded-md bg-rose-900/30 text-rose-400 border border-rose-800';
              messageDiv.textContent = 'Las contraseñas no coinciden. Por favor, verifique e intente de nuevo.';
              messageDiv.classList.remove('hidden');
            }
            return;
          }

          submitBtn.innerHTML = 'Creando cuenta...';
          submitBtn.disabled = true;

          const email = (document.getElementById('admin-email') as HTMLInputElement).value;
          const metadata = getFormData();

          try {
            const { data, error } = await supabase.auth.signUp({
              email,
              password,
              options: {
                data: metadata
              }
            });

            if (error) throw error;

            if (messageDiv) {
              messageDiv.className = 'text-sm p-3 rounded-md bg-emerald-900/30 text-emerald-400 border border-emerald-800';
              messageDiv.textContent = '¡Cuenta creada con éxito! Redirigiendo a su centro de mando...';
              messageDiv.classList.remove('hidden');
            }

            setTimeout(() => {
              window.location.href = '/dashboard';
            }, 2000);

          } catch (error: any) {
            if (messageDiv) {
              messageDiv.className = 'text-sm p-3 rounded-md bg-rose-900/30 text-rose-400 border border-rose-800';
              messageDiv.textContent = error.message || 'Ocurrió un error al crear la cuenta.';
              messageDiv.classList.remove('hidden');
            }
          } finally {
            submitBtn.innerHTML = 'Crear Cuenta con Contraseña';
            submitBtn.disabled = false;
          }
        });
      }
    </script>
  </body>
</html>