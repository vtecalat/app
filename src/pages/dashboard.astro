---
import '../styles/global.css';
---

<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Centro de Mando | Vteca</title>
  </head>
  <body id="dashboard-body" class="bg-stone-50 dark:bg-slate-950 text-slate-900 dark:text-stone-100 h-screen flex opacity-0 transition-opacity duration-500">
    
    <aside id="sidebar" class="w-64 bg-white dark:bg-[#1a1c23] border-r border-slate-200 dark:border-slate-800 flex flex-col z-20">
      <div class="h-20 flex items-center px-8 border-b border-slate-200 dark:border-slate-800">
        <div class="text-2xl font-bold tracking-tighter text-slate-900 dark:text-white">vteca<span class="text-blue-600">.</span></div>
      </div>
      
      <nav class="flex-1 p-4 space-y-1">
        <div id="nav-content" class="hidden space-y-1">
           <a href="#" class="flex items-center px-4 py-3 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 rounded-lg font-semibold text-sm">Resumen</a>
           <a href="#" class="flex items-center px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg text-sm">Crear Sesión</a>
        </div>
      </nav>

      <div class="p-4 border-t border-slate-200 dark:border-slate-800">
        <button id="theme-toggle" class="w-full text-xs font-bold uppercase p-2 mb-2 rounded hover:bg-slate-200 dark:hover:bg-slate-800">Cambiar Modo</button>
        <button id="logout-btn" class="w-full text-xs text-rose-500 font-bold uppercase p-2 hover:bg-rose-50 dark:hover:bg-rose-950/30 rounded">Cerrar Sesión</button>
      </div>
    </aside>

    <main class="flex-1 overflow-y-auto p-8">
      <header class="flex justify-between items-center mb-10">
        <div>
          <h1 id="inst-name" class="text-3xl font-black">Cargando datos...</h1>
          <p class="text-slate-500">Gestión de infraestructura audiovisual.</p>
        </div>
      </header>

      <div id="pending-state" class="hidden bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-900/50 p-10 rounded-2xl text-center">
        <h2 class="text-xl font-bold text-amber-800 dark:text-amber-500 mb-2">Entorno en auditoría</h2>
        <p class="text-sm text-amber-700/80 dark:text-amber-500/70 max-w-md mx-auto">Su cuenta está siendo verificada por nuestro equipo técnico. Recibirá una notificación cuando su infraestructura esté activa.</p>
      </div>

      <div id="active-state" class="hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
           <div class="p-8 bg-white dark:bg-[#1a1c23] border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm">
             <h2 class="font-bold mb-4">Módulo de Sesiones</h2>
             <p class="text-sm text-slate-500">Integración de Epistecnología aquí...</p>
           </div>
        </div>
      </div>
    </main>

    <script>
    import { supabase } from '../lib/supabase.js';

    document.addEventListener('DOMContentLoaded', async () => {
        const body = document.getElementById('dashboard-body');
        
        // 1. Verificar sesión
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) {
        window.location.replace('/login');
        return;
        }

        // 2. Obtener perfil con manejo de errores si no existe
        const { data: profile, error } = await supabase
        .from('profiles')
        .select('*, institutions(*)')
        .eq('id', user.id)
        .single();

        if (error || !profile || !profile.institutions) {
        console.error('Error al cargar perfil o institución:', error);
        document.getElementById('inst-name')!.textContent = 'Error: Perfil no vinculado';
        return;
        }

        // 3. Si todo está bien, mostrar datos
        document.getElementById('inst-name')!.textContent = profile.institutions.name;
        body!.classList.remove('opacity-0');

        if (profile.institutions.status === 'active') {
        document.getElementById('active-state')!.classList.remove('hidden');
        document.getElementById('nav-content')!.classList.remove('hidden');
        } else {
        document.getElementById('pending-state')!.classList.remove('hidden');
        }
    });
    </script>
  </body>
</html>