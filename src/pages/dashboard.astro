---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Centro de Mando | Vteca</title>
  </head>
  <body id="dashboard-body" class="bg-slate-950 text-stone-100 font-sans antialiased h-screen flex overflow-hidden opacity-0 transition-opacity duration-300">
    
    <aside class="w-64 bg-[#1a1c23] border-r border-slate-800 flex flex-col justify-between hidden md:flex z-20 shadow-xl">
      <div>
        <div class="h-20 flex items-center px-8 border-b border-slate-800/60">
          <div class="text-2xl font-bold tracking-tighter">vteca<span class="text-blue-600">.</span></div>
        </div>

        <nav class="p-4 space-y-2">
          <p class="px-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-4 mt-4">Gestión de Acervo</p>
          
          <a href="#" class="flex items-center space-x-3 px-4 py-3 bg-blue-900/20 text-blue-400 rounded-lg border border-blue-900/30 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
            <span class="text-sm font-semibold">Resumen</span>
          </a>
          
          <a href="#" class="flex items-center space-x-3 px-4 py-3 text-slate-400 hover:text-stone-100 hover:bg-slate-800/50 rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <span class="text-sm font-medium">Crear Sesión (Metadatos)</span>
          </a>

          <a href="#" class="flex items-center space-x-3 px-4 py-3 text-slate-400 hover:text-stone-100 hover:bg-slate-800/50 rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
            <span class="text-sm font-medium">Ingesta de Video</span>
          </a>
        </nav>
      </div>

      <div class="p-4 border-t border-slate-800/60">
        <button id="logout-btn" class="flex items-center space-x-3 px-4 py-3 w-full text-slate-400 hover:text-rose-400 hover:bg-rose-950/30 rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
          <span class="text-sm font-medium">Cerrar Sesión</span>
        </button>
      </div>
    </aside>

    <main class="flex-1 flex flex-col h-screen overflow-y-auto bg-[url('/noise.png')] relative">
      <header class="md:hidden h-16 border-b border-slate-800 flex items-center justify-between px-6 bg-[#1a1c23]">
        <div class="text-xl font-bold tracking-tighter">vteca<span class="text-blue-600">.</span></div>
        <button class="text-slate-400"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg></button>
      </header>

      <div class="p-8 lg:p-12 max-w-6xl mx-auto w-full">
        
        <header class="mb-10">
          <h1 class="text-3xl font-bold text-stone-100 tracking-tight">Centro de Mando</h1>
          <p class="text-slate-400 mt-2">Bienvenido a su infraestructura de gestión audiovisual.</p>
        </header>

        <div class="grid lg:grid-cols-3 gap-6">
          
          <div class="lg:col-span-2 bg-[#1a1c23]/80 border border-slate-800 rounded-2xl p-8 shadow-lg backdrop-blur-sm">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-lg font-bold text-stone-100">Nueva Sesión Académica</h2>
              <span class="px-3 py-1 bg-blue-900/30 text-blue-400 border border-blue-800/50 rounded-full text-xs font-semibold">Módulo Activo</span>
            </div>
            
            <div class="border-2 border-dashed border-slate-700 rounded-xl h-64 flex flex-col items-center justify-center text-slate-500 bg-slate-900/50">
              <svg class="w-10 h-10 mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
              <p class="text-sm">Área de trabajo reservada para el sistema de metadatos.</p>
              <p class="text-xs mt-1">Esperando integración del código de Epistecnología...</p>
            </div>
          </div>

          <div class="space-y-6">
            <div class="bg-[#1a1c23]/80 border border-slate-800 rounded-2xl p-6 shadow-lg backdrop-blur-sm">
              <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Estado de Red</h3>
              <div class="flex items-center space-x-3">
                <span class="flex h-3 w-3 rounded-full bg-emerald-500 animate-pulse"></span>
                <span class="text-sm text-stone-200">Nube Privada Operativa</span>
              </div>
            </div>

            <div class="bg-[#1a1c23]/80 border border-slate-800 rounded-2xl p-6 shadow-lg backdrop-blur-sm">
              <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Conexión Indexación</h3>
              <div class="flex items-center space-x-3 text-slate-400">
                <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                <span class="text-sm">Zenodo API (Pendiente)</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </main>

    <script>
      import { supabase } from '../lib/supabase.js';

      document.addEventListener('DOMContentLoaded', async () => {
        const body = document.getElementById('dashboard-body');
        
        // 1. Verificar si hay sesión activa
        const { data: { session }, error } = await supabase.auth.getSession();

        if (!session) {
          // Si no hay sesión, expulsar al login
          window.location.replace('/login');
          return;
        }

        // Si hay sesión, mostramos el dashboard (quitamos opacity-0)
        if (body) {
          body.classList.remove('opacity-0');
        }

        // 2. Interceptar el "setup" de Google SSO
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('setup') === 'true') {
          const pendingData = localStorage.getItem('vteca_pending_registration');
          
          if (pendingData) {
            try {
              const metadata = JSON.parse(pendingData);
              // Inyectar la metadata institucional en el perfil de Supabase
              await supabase.auth.updateUser({
                data: metadata
              });
              console.log('Metadatos de Google SSO guardados exitosamente.');
              // Limpiar datos temporales
              localStorage.removeItem('vteca_pending_registration');
              // Limpiar la URL para que no vuelva a ejecutarse
              window.history.replaceState({}, document.title, '/dashboard');
            } catch (err) {
              console.error('Error al guardar metadata de Google:', err);
            }
          }
        }

        // 3. Funcionalidad de Cerrar Sesión
        const logoutBtn = document.getElementById('logout-btn');
        if (logoutBtn) {
          logoutBtn.addEventListener('click', async () => {
            await supabase.auth.signOut();
            window.location.href = '/login';
          });
        }
      });
    </script>
  </body>
</html>