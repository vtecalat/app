---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso Institucional | Vteca</title>
  </head>
  <body class="bg-slate-900 text-stone-100 font-sans antialiased min-h-screen flex items-center justify-center p-6">
    
    <div class="w-full max-w-md">
      <div class="text-center mb-10">
        <div class="text-3xl font-bold tracking-tighter mb-2">vteca<span class="text-blue-900">.</span></div>
        <h1 class="text-2xl font-semibold text-stone-100">Acceso Institucional</h1>
        <p class="text-slate-400 text-sm mt-2">Ingrese sus credenciales de administrador.</p>
      </div>

      <div class="bg-[#1a1c23] border border-slate-700/50 p-8 rounded-xl shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-900 via-slate-700 to-rose-900"></div>

        <form id="login-form" class="space-y-6">
          <div class="space-y-4 pt-2">
            <div>
              <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Correo Institucional</label>
              <input type="email" id="email" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-blue-900 transition-colors" placeholder="admin@universidad.edu">
            </div>
            
            <div>
              <div class="flex justify-between items-center mb-1">
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest">Contraseña</label>
                <a href="#" class="text-xs text-blue-800 hover:text-blue-700 transition-colors">¿Olvidó su clave?</a>
              </div>
              <input type="password" id="password" required class="w-full bg-slate-900/50 border border-slate-700 rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-blue-900 transition-colors" placeholder="••••••••">
            </div>
          </div>

          <div id="login-message" class="hidden text-sm p-3 rounded-md"></div>

          <button type="submit" id="login-btn" class="w-full py-3 bg-blue-950 text-stone-100 border border-blue-900 hover:bg-blue-900 font-semibold rounded-md transition-colors text-sm flex justify-center items-center mt-4">
            Ingresar al Sistema
          </button>
        </form>
        
        <div class="mt-6 text-center text-xs text-slate-500 border-t border-slate-700/50 pt-6">
          ¿Aún no tiene un entorno aprovisionado? <br/>
          <a href="/registro" class="text-blue-800 hover:text-blue-700 font-semibold mt-1 inline-block">Solicitar infraestructura de Vteca</a>
        </div>
      </div>
    </div>

    <script>
      import { supabase } from '../lib/supabase.js';

      const form = document.getElementById('login-form');
      const messageDiv = document.getElementById('login-message');
      const loginBtn = document.getElementById('login-btn');

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          if(loginBtn) loginBtn.innerHTML = 'Autenticando...';
          if(loginBtn) (loginBtn as HTMLButtonElement).disabled = true;

          const email = (document.getElementById('email') as HTMLInputElement).value;
          const password = (document.getElementById('password') as HTMLInputElement).value;

          try {
            const { data, error } = await supabase.auth.signInWithPassword({
              email,
              password,
            });

            if (error) throw error;

            if (messageDiv) {
              messageDiv.className = 'text-sm p-3 rounded-md bg-emerald-900/30 text-emerald-400 border border-emerald-800';
              messageDiv.textContent = 'Acceso concedido. Redirigiendo...';
              messageDiv.classList.remove('hidden');
            }

            // Redirigir al dashboard
            setTimeout(() => {
              window.location.href = '/dashboard';
            }, 1000);

          } catch (error: any) {
            if (messageDiv) {
              messageDiv.className = 'text-sm p-3 rounded-md bg-rose-900/30 text-rose-400 border border-rose-800';
              messageDiv.textContent = 'Credenciales inválidas. Verifique su correo o contraseña.';
              messageDiv.classList.remove('hidden');
            }
          } finally {
            if(loginBtn) loginBtn.innerHTML = 'Ingresar al Sistema';
            if(loginBtn) (loginBtn as HTMLButtonElement).disabled = false;
          }
        });
      }
    </script>
  </body>
</html>